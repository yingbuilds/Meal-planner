      const start = raw.indexOf("{");
      const end = raw.lastIndexOf("}");
      if (start === -1 || end === -1) throw new Error("no JSON in response");
      const json = JSON.parse(raw.slice(start, end + 1));
      const ingredients = (json.ingredients || []).map(ing => ({
        name: ing.name, quantity: ing.quantity || "", unit: ing.unit || "",
        optional: false, ...(ing.unusual ? { note: "特殊调料" } : {})
      }));
      const steps = (json.steps || []).map((s, i) => ({ step_number: i + 1, instruction: s.instruction || "", tip: s.tip || "" }));
      const category = normalizeCategory(json.category);
      setForm(f => ({
        ...f,
        name: json.name || f.name,
        category,
        image: CATEGORY_EMOJI[category] || f.image,
        ingredients: ingredients.length > 0 ? ingredients : f.ingredients,
        steps: steps.length > 0 ? steps : f.steps,
      }));
      setShowImport(false);
      setImportUrl("");
      setImportFreeText("");
      showToast("✓ AI 已识别，请确认菜名和分类");
    } catch (e) {
      console.error("Import AI error, falling back to regex:", e);
      const fb = parseRecipeFromText(rawText);
      const category = fb.category || "其他";
      setForm(f => ({
        ...f,
        name: fb.name || f.name,
        category,
        image: CATEGORY_EMOJI[category] || f.image,
        ingredients: fb.ingredients.length > 0 ? fb.ingredients : f.ingredients,
        steps: fb.steps.length > 0 ? fb.steps : f.steps,
      }));
      setShowImport(false);
      setImportUrl("");
      setImportFreeText("");
      showToast("✓ 已识别（离线模式），请确认菜名和分类");
    }
    setImportParsing(false);
  };

  const optimizeTextToSteps = (text) => {
    let chunks = text.split(/(?=[1-9][.。、）\)]\s*)|(?=第[一二三四五六七八九十]步)/).map(s => s.trim()).filter(Boolean);
    if (chunks.length <= 1) chunks = text.split(/[。；;]\s*/).map(s => s.trim()).filter(s => s.length > 2);
    if (chunks.length <= 1) chunks = text.split(/(?=[，,]\s*(?:先|然后|接着|再|最后|下|放|加|炒|煮|焖|蒸|炸|烤|切|洗|腌|调|翻|盛|出锅))/).map(s => s.replace(/^[，,]\s*/, "").trim()).filter(s => s.length > 2);
    return chunks.map((chunk, i) => ({
      step_number: i + 1,
      instruction: chunk.replace(/^[1-9①②③④⑤⑥⑦⑧⑨][.。、\)）\s]*/, "").replace(/^第[一二三四五六七八九十]步[：:：]?\s*/, "").trim(),
      tip: ""
    })).filter(s => s.instruction.length > 0);
  };

  const handleOptimizeFreeText = async () => {
    if (!freeText.trim()) return;
