    ings: ["生抽 2勺","盐 适量","食用油 2勺","葱 2根","姜 2片"]
  };

  let tpl = defaultTemplate;
  for (const key of Object.keys(templates)) {
    if (name.includes(key)) { tpl = templates[key]; break; }
  }

  const category = tpl.category || inferCategory(name) || "猪肉";
  const allIngs = [...(tpl.mainIng || []), ...tpl.ings];

  return {
    category,
    steps: tpl.steps.map((instruction, i) => ({ step_number: i + 1, instruction, tip: "" })),
    ingredients: allIngs.map(s => {
      const parts = s.split(" ");
      return { name: parts[0], quantity: parts[1] || "", unit: parts[2] || "", optional: false };
    })
  };
}

function parseStepsFromText(text) {
  const lines = text.split(/\n+/).map(l => l.trim()).filter(Boolean);
  return lines.map((line, i) => ({
    step_number: i + 1,
    instruction: line.replace(/^[\d]+[\.、。\)）\s]+/, "").trim(),
    tip: ""
  })).filter(s => s.instruction.length > 0);
}

