返回严格的JSON格式，不要加任何解释或markdown代码块：
[{"step_number":1,"instruction":"步骤说明","tip":"小技巧或空字符串"}]
要求：每步聚焦一个动作，语言简洁，保留原文的关键细节。

做法文字：
${freeText.trim()}`
      );
      const _sa=raw.indexOf("["),_ea=raw.lastIndexOf("]");
      const steps = (JSON.parse(_sa>-1&&_ea>-1 ? raw.slice(_sa,_ea+1) : "[]") || []).map((s, i) => ({ step_number: i + 1, instruction: s.instruction || "", tip: s.tip || "" }));
      update("steps", steps); autoPopulateFromSteps(steps);
      setStepsMode("structured");
      setFreeText("");
      showToast(`✨ AI 已整理步骤`);
    } catch (e) {
      console.error("Optimize AI error, falling back to regex:", e);
      const steps = optimizeTextToSteps(freeText.trim());
      update("steps", steps); autoPopulateFromSteps(steps);
      setStepsMode("structured");
      setFreeText("");
      showToast(`✓ 已整理步骤（离线模式）`);
    }
    setOptimizing(false);
  };

