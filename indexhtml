            <div style={{ marginBottom: 24 }}>
              <div style={{ fontSize: 13, fontWeight: 700, color: "#5a5550", marginBottom: 10 }}>计划天数</div>
              <div style={{ display: "flex", gap: 8 }}>
                {[5, 7].map(n => (
                  <button key={n} onClick={() => setPlanSettings(s => ({ ...s, days: n }))} style={{
                    flex: 1, padding: "12px", borderRadius: 12, border: "none", cursor: "pointer",
                    background: planSettings.days === n ? "#1a1714" : "#f5f0ea",
                    color: planSettings.days === n ? "#fff" : "#5a5550",
                    fontWeight: 700, fontSize: 15, WebkitTapHighlightColor: "transparent"
                  }}>{n}天</button>
                ))}
              </div>
            </div>

            <div style={{ marginBottom: 24 }}>
              <div style={{ fontSize: 13, fontWeight: 700, color: "#5a5550", marginBottom: 10 }}>餐次 &amp; 荤素配比</div>
              <div style={{ display: "flex", flexDirection: "column", gap: 8 }}>
                {[["breakfast","早餐"],["lunch","午餐"],["dinner","晚餐"]].map(([key, label]) => {
                  const active = planSettings.meals[key];
                  const comp = planSettings.mealComposition?.[key] || { meat: 1, veg: 0 };
                  const setComp = (field, delta) => setPlanSettings(s => {
                    const cur = s.mealComposition?.[key] || { meat: 1, veg: 0 };
                    const next = Math.max(0, Math.min(5, (cur[field] || 0) + delta));
                    return { ...s, mealComposition: { ...s.mealComposition, [key]: { ...cur, [field]: next } } };
                  });
                  return (
                    <div key={key} style={{
                      borderRadius: 14, background: active ? "#fff8ed" : "#f5f0ea",
                      border: active ? "1.5px solid #c17f3c" : "1.5px solid transparent", overflow: "hidden"
                    }}>
                      <button onClick={() => setPlanSettings(s => ({ ...s, meals: { ...s.meals, [key]: !s.meals[key] } }))} style={{
                        width: "100%", display: "flex", justifyContent: "space-between", alignItems: "center",
                        padding: "14px 16px", background: "none", border: "none", cursor: "pointer", WebkitTapHighlightColor: "transparent"
                      }}>
                        <span style={{ fontSize: 15, fontWeight: 600, color: "#1a1714" }}>{label}</span>
                        <div style={{
                          width: 24, height: 24, borderRadius: 8, background: active ? "#c17f3c" : "#d4cdc5",
                          display: "flex", alignItems: "center", justifyContent: "center", color: "#fff", fontSize: 14, fontWeight: 700
                        }}>{active ? "✓" : ""}</div>
                      </button>
                      {active && (
                        <div style={{ padding: "0 16px 14px", display: "flex", flexDirection: "column", gap: 10 }}>
                          {[["meat","🥩 荤菜"],["veg","🥦 素菜"]].map(([field, fieldLabel]) => (
                            <div key={field} style={{ display: "flex", justifyContent: "space-between", alignItems: "center" }}>
                              <span style={{ fontSize: 14, color: "#5a5550", fontWeight: 500 }}>{fieldLabel}</span>
                              <div style={{ display: "flex", alignItems: "center", gap: 0 }}>
                                <button onClick={() => setComp(field, -1)} style={{
                                  width: 32, height: 32, borderRadius: "8px 0 0 8px", background: "#f0ebe3",
                                  border: "none", fontSize: 18, color: "#5a5550", cursor: "pointer",
                                  display: "flex", alignItems: "center", justifyContent: "center", fontWeight: 700,
                                  WebkitTapHighlightColor: "transparent"
                                }}>−</button>
                                <div style={{
                                  width: 36, height: 32, background: "#fff", display: "flex",
                                  alignItems: "center", justifyContent: "center",
                                  fontSize: 15, fontWeight: 700, color: "#1a1714",
                                  borderTop: "1px solid #e8e0d4", borderBottom: "1px solid #e8e0d4"
                                }}>{comp[field] ?? 0}</div>
                                <button onClick={() => setComp(field, +1)} style={{
                                  width: 32, height: 32, borderRadius: "0 8px 8px 0", background: "#f0ebe3",
                                  border: "none", fontSize: 18, color: "#5a5550", cursor: "pointer",
                                  display: "flex", alignItems: "center", justifyContent: "center", fontWeight: 700,
                                  WebkitTapHighlightColor: "transparent"
                                }}>＋</button>
                              </div>
                            </div>
                          ))}
                          <div style={{ fontSize: 12, color: "#b0a89e", marginTop: 2 }}>
                            共 {(comp.meat || 0) + (comp.veg || 0)} 道菜 · 荤 {comp.meat || 0} 素 {comp.veg || 0}
                          </div>
                        </div>
                      )}
                    </div>
                  );
                })}
              </div>
            </div>

            <button onClick={() => {
              setShowSettings(false);
              if (mealPlan && JSON.stringify(planSettings) !== settingsSnapshot) handleGenerate();
            }} className="btn-primary" style={{ width: "100%" }}>
              完成
            </button>
          </div>
        </div>
      )}
    </div>
  );
}

// ─── GROCERY SCREEN ───────────────────────────────────────────────
function GroceryScreen({ groceryList, setGroceryList, showToast }) {
  const grouped = useMemo(() => groupBy(groceryList?.items || [], "category"), [groceryList]);
  const totalChecked = groceryList?.items?.filter(i => i.checked).length || 0;
  const total = groceryList?.items?.length || 0;

  const toggleItem = (id) => {
    setGroceryList(prev => ({
      ...prev,
      items: prev.items.map(item => item.id === id ? { ...item, checked: !item.checked } : item)
    }));
  };

  if (!groceryList) {
    return (
      <div className="screen">
        <div style={{ padding: "52px 20px" }}><div className="screen-title">采购清单</div></div>
        <div className="empty-state">
          <div className="empty-icon">🛒</div>
          <div className="section-title">还没有采购清单</div>
          <div className="body-text">先生成每周菜单，系统会自动生成采购清单</div>
        </div>
      </div>
    );
  }

  return (
    <div className="screen">
      <div style={{ padding: "52px 20px 16px" }}>
        <div className="screen-title">采购清单</div>
        <div style={{ marginTop: 12, background: "#f5f0ea", borderRadius: 14, padding: "12px 16px" }}>
          <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 8 }}>
            <div className="body-text">已买 {totalChecked} / 共 {total} 项</div>
            <button onClick={() => { setGroceryList(prev => ({ ...prev, items: prev.items.map(i => ({ ...i, checked: false })) })); showToast("已重置！"); }}
              style={{ background: "none", border: "none", fontSize: 13, color: "#9a9590", cursor: "pointer", fontWeight: 600 }}>重置</button>
          </div>
          <div style={{ height: 6, background: "#d4cdc5", borderRadius: 3, overflow: "hidden" }}>
            <div style={{ height: "100%", background: "#c17f3c", borderRadius: 3, width: `${(totalChecked / total) * 100}%`, transition: "width 0.3s" }} />
          </div>
        </div>
      </div>

      <div style={{ padding: "0 20px 20px" }}>
        {Object.entries(grouped).map(([category, items]) => (
          <div key={category} style={{ marginBottom: 20 }}>
            <div style={{ fontSize: 13, fontWeight: 700, color: "#c17f3c", letterSpacing: 0.5, textTransform: "uppercase", marginBottom: 4 }}>
              {category}
            </div>
            <div className="card" style={{ padding: "0 16px" }}>
              {items.map(item => (
                <div key={item.id} className="checkbox-row" onClick={() => toggleItem(item.id)}>
                  <div className={`checkbox ${item.checked ? "checked" : ""}`}>
                    {item.checked && <span style={{ color: "#fff", fontSize: 14, fontWeight: 700 }}>✓</span>}
                  </div>
                  <div style={{ flex: 1 }}>
                    <div style={{ fontSize: 15, color: item.checked ? "#b0a89e" : "#1a1714", textDecoration: item.checked ? "line-through" : "none", fontWeight: 500 }}>
                      {item.name}
                    </div>
                  </div>
                  <div style={{ fontSize: 14, color: item.checked ? "#b0a89e" : "#5a5550", fontWeight: 600 }}>
                    {item.quantity} {item.unit}
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}

        <button className="btn-primary" onClick={() => showToast("📋 采购清单已复制！")}>
          📋 分享采购清单
        </button>
      </div>
    </div>
  );
}

