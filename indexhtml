                              fontSize: 13, color: "#7a7570", cursor: "pointer", WebkitTapHighlightColor: "transparent",
                              display: "flex", alignItems: "center", justifyContent: "center"
                            }}>↔</button>
                            <button onClick={() => removeDishFromSlot(dishId, dayIndex, mealType)} style={{
                              width: 30, height: 30, borderRadius: 8, background: "#fef0ee", border: "none",
                              fontSize: 13, color: "#d05a3a", cursor: "pointer", WebkitTapHighlightColor: "transparent",
                              display: "flex", alignItems: "center", justifyContent: "center"
                            }}>×</button>
                          </div>
                        );
                      })}
                      <button onClick={() => setAddDishModal({ dayIndex, mealType })} style={{
                        display: "flex", alignItems: "center", gap: 6, padding: "6px 10px", background: "none",
                        border: "1.5px dashed #d4cdc5", borderRadius: 10, fontSize: 13, color: "#9a9590",
                        cursor: "pointer", WebkitTapHighlightColor: "transparent"
                      }}>+ 添加菜品</button>
                    </div>
                  </div>
                );
              })}

              {day.notes ? (
                <div style={{ marginTop: 10, padding: "8px 10px", background: "#fff8ed", borderRadius: 10, fontSize: 12, color: "#8a6030", lineHeight: 1.4 }}>
                  📌 {day.notes}
                </div>
              ) : null}
            </div>
          ))}

          <button className="btn-primary" onClick={() => { onNavigate("share"); showToast("📤 正在打开厨师视图"); }}>
            📤 分享给厨师
          </button>
          <button className="btn-secondary" onClick={() => onNavigate("grocery")}>
            🛒 查看采购清单
          </button>
          <button className="btn-secondary" onClick={handleGenerate} style={{ color: "#9a9590" }}>
            🔄 重新生成全部
          </button>
        </div>
      )}

      {/* Swap modal */}
      {swapModal && (() => {
        const q = swapSearch.trim().toLowerCase();
        const filtered = dishes.filter(d => d.id !== swapModal.dishId && (!q || d.name.toLowerCase().includes(q) || d.category.includes(q)));
        return (
