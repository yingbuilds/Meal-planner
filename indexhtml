// ─── COOKING MODE ─────────────────────────────────────────────────
function CookingModeScreen({ dish, onClose }) {
  const [currentStep, setCurrentStep] = useState(0);

  if (!dish) return null;

  const step = dish.steps[currentStep];
  const isLast = currentStep === dish.steps.length - 1;

  return (
    <div className="cooking-mode">
      {/* Header */}
      <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", marginBottom: 32 }}>
        <div>
          <div style={{ fontSize: 12, color: "#8a7060", letterSpacing: 1 }}>烹饪模式</div>
          <div style={{ fontSize: 20, fontWeight: 700, color: "#fff", marginTop: 4 }}>{dish.name}</div>
        </div>
        <button onClick={onClose} style={{ background: "#3a3530", border: "none", borderRadius: 12, padding: "8px 14px", color: "#9a8a7a", fontSize: 14, fontWeight: 600, cursor: "pointer" }}>完成</button>
      </div>

      {/* My notes (always visible in cooking mode) */}
      {dish.custom_notes.length > 0 && (
        <div style={{ background: "#3d2e1a", borderRadius: 16, padding: 14, marginBottom: 24, borderLeft: "3px solid #c17f3c" }}>
          <div style={{ fontSize: 11, color: "#c17f3c", fontWeight: 700, letterSpacing: 0.5, marginBottom: 8 }}>我的备注</div>
          {dish.custom_notes.slice(0, 2).map((note, i) => (
            <div key={i} style={{ fontSize: 13, color: "#e0c090", lineHeight: 1.5, marginBottom: 4 }}>• {note}</div>
          ))}
        </div>
      )}

      {/* Progress */}
      <div style={{ display: "flex", gap: 6, marginBottom: 24 }}>
        {dish.steps.map((_, i) => (
          <button key={i} onClick={() => setCurrentStep(i)} style={{
            flex: 1, height: 4, borderRadius: 2, border: "none", cursor: "pointer",
            background: i <= currentStep ? "#c17f3c" : "#3a3530",
            transition: "background 0.2s"
          }} />
        ))}
      </div>

      {/* Current step */}
      <div className="cooking-step-card current">
        <div style={{ display: "flex", alignItems: "center", gap: 10, marginBottom: 16 }}>
          <div style={{ width: 36, height: 36, borderRadius: 12, background: "#c17f3c", display: "flex", alignItems: "center", justifyContent: "center", fontSize: 16, fontWeight: 800, color: "#fff" }}>{step.step_number}</div>
          <div style={{ fontSize: 12, color: "#c17f3c", fontWeight: 600, letterSpacing: 0.5 }}>当前步骤</div>
        </div>
        <div style={{ fontSize: 20, color: "#fff", lineHeight: 1.6, fontWeight: 500 }}>{step.instruction}</div>
        {step.tip && (
          <div style={{ marginTop: 16, padding: "12px 14px", background: "#5a3a14", borderRadius: 12, fontSize: 14, color: "#f0c070", lineHeight: 1.4 }}>
            💡 {step.tip}
          </div>
        )}
      </div>

      {/* Prev / Next */}
      <div style={{ display: "flex", gap: 12, marginTop: 20 }}>
        <button
          onClick={() => setCurrentStep(Math.max(0, currentStep - 1))}
          disabled={currentStep === 0}
          style={{ flex: 1, background: "#2a2520", border: "none", borderRadius: 14, padding: 16, fontSize: 15, fontWeight: 600, color: currentStep === 0 ? "#4a4540" : "#c0a070", cursor: currentStep === 0 ? "default" : "pointer" }}
        >← 上一步</button>
        <button
          onClick={() => isLast ? onClose() : setCurrentStep(currentStep + 1)}
          style={{ flex: 1, background: "#c17f3c", border: "none", borderRadius: 14, padding: 16, fontSize: 15, fontWeight: 600, color: "#fff", cursor: "pointer" }}
        >{isLast ? "完成！🎉" : "下一步 →"}</button>
      </div>

      {/* Upcoming */}
      {!isLast && (
        <div style={{ marginTop: 20 }}>
