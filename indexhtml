}

// ─── DISH LIBRARY ─────────────────────────────────────────────────
function DishLibraryScreen({ dishes, setDishes, onNavigate }) {
  const [search, setSearch] = useState("");
  const [category, setCategory] = useState("All");

  const filtered = dishes.filter(d => {
    const matchSearch = d.name.toLowerCase().includes(search.toLowerCase());
    const matchCat = category === "All" || d.category === category;
    return matchSearch && matchCat;
  });

  const toggleFavorite = (id) => {
    setDishes(prev => prev.map(d => d.id === id ? { ...d, is_favorite: !d.is_favorite } : d));
  };

  return (
    <div className="screen">
      <div style={{ padding: "52px 20px 16px" }}>
        <div className="screen-title">菜品库</div>
        <div style={{ marginTop: 14 }} className="search-bar">
          <span>🔍</span>
          <input
            value={search}
            onChange={e => setSearch(e.target.value)}
            placeholder="搜索菜品..."
          />
          {search && <button className="btn-icon" onClick={() => setSearch("")} style={{ color: "#9a9590", fontSize: 16 }}>✕</button>}
        </div>
        <div className="chips-row" style={{ marginTop: 12 }}>
          {CATEGORIES.map(cat => (
            <button key={cat} className={`chip ${category === cat ? "chip-active" : "chip-inactive"}`} onClick={() => setCategory(cat)}>
              {cat}
            </button>
          ))}
        </div>
        <button className="btn-primary" style={{ width: "100%", marginTop: 14 }} onClick={() => onNavigate("add-dish")}>+ 添加新菜品</button>
      </div>

      <div style={{ padding: "0 20px 20px", display: "flex", flexDirection: "column", gap: 12 }}>
        {filtered.length === 0 ? (
          <div className="empty-state">
            <div className="empty-icon">🍽️</div>
            <div className="section-title">没找到菜品</div>
            <div className="body-text">换个关键词搜索，或添加新菜品</div>
            <button className="btn-primary" style={{ marginTop: 8 }} onClick={() => onNavigate("add-dish")}>+ 添加菜品</button>
          </div>
        ) : filtered.map(dish => (
          <button key={dish.id} onClick={() => onNavigate("dish-detail", dish.id)}
            style={{ background: "#fff", borderRadius: 18, padding: 0, border: "none", cursor: "pointer", textAlign: "left", boxShadow: "0 1px 4px rgba(0,0,0,0.06)", overflow: "hidden", WebkitTapHighlightColor: "transparent" }}>
            <div style={{ display: "flex", alignItems: "center", gap: 14, padding: "14px 16px" }}>
              <div style={{ fontSize: 40, width: 56, height: 56, display: "flex", alignItems: "center", justifyContent: "center", background: "#fdf3e7", borderRadius: 14, flexShrink: 0 }}>
                {dish.image}
              </div>
              <div style={{ flex: 1, minWidth: 0 }}>
                <div style={{ display: "flex", alignItems: "center", gap: 6, marginBottom: 4 }}>
                  <div style={{ fontSize: 16, fontWeight: 700, color: "#1a1714" }}>{dish.name}</div>
                </div>
                <div style={{ display: "flex", gap: 6, flexWrap: "wrap" }}>
                  <span className="badge badge-category">{dish.category}</span>
                  <span className={`badge badge-${dish.difficulty}`}>{dish.difficulty === "easy" ? "简单" : dish.difficulty === "medium" ? "中等" : "较难"}</span>
                  <span className="caption" style={{ alignSelf: "center" }}>⏱ {dish.estimated_time}分钟</span>
                </div>
                {dish.custom_notes.length > 0 && (
                  <div style={{ fontSize: 12, color: "#c17f3c", marginTop: 5, fontStyle: "italic" }}>
                    "{dish.custom_notes[0].slice(0, 50)}..."
                  </div>
                )}
              </div>
              <button
                onClick={e => { e.stopPropagation(); toggleFavorite(dish.id); }}
                style={{ background: "none", border: "none", fontSize: 22, cursor: "pointer", color: dish.is_favorite ? "#e53935" : "#d4cdc5", padding: "8px 4px", WebkitTapHighlightColor: "transparent" }}
              >
                {dish.is_favorite ? "♥" : "♡"}
              </button>
            </div>
          </button>
        ))}

      </div>
    </div>
  );
}

// ─── DISH DETAIL ──────────────────────────────────────────────────
function DishDetailScreen({ dish, onBack, onCookingMode, onEdit, onToggleFavorite, onUpdateImage, chefMode }) {
  const [activeSection, setActiveSection] = useState("notes");
  const [showImgPicker, setShowImgPicker] = useState(false);

  const handleImgFile = (e) => {
    const file = e.target.files && e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = ev => { onUpdateImage && onUpdateImage(ev.target.result); setShowImgPicker(false); };
    reader.readAsDataURL(file);
  };

  if (!dish) return null;

  const sourceBadge = (type) => {
    if (type === "youtube") return <span className="badge badge-youtube">▶ YouTube</span>;
    if (type === "xiaohongshu") return <span className="badge badge-xiaohongshu">📕 小红书</span>;
    return <span className="badge badge-web">🌐 Web</span>;
  };

  return (
    <div className="screen">
      {/* Image header */}
      <div style={{ position: "relative" }}>
        <div onClick={() => !chefMode && setShowImgPicker(true)} style={{ cursor: chefMode ? "default" : "pointer" }}>
          {dish.imageUrl ? (
            <div style={{ width: "100%", height: 220, overflow: "hidden" }}>
              <img src={dish.imageUrl} alt={dish.name} style={{ width: "100%", height: "100%", objectFit: "cover" }} />
            </div>
          ) : (
            <div className="dish-image-placeholder" style={{ borderRadius: 0 }}>
              <span style={{ fontSize: 80 }}>{dish.image}</span>
            </div>
          )}
          {!chefMode && (
            <div style={{ position: "absolute", bottom: 12, right: 12, background: "rgba(0,0,0,0.45)", borderRadius: 20, padding: "5px 12px", fontSize: 12, color: "#fff", backdropFilter: "blur(4px)" }}>
              📷 换图
            </div>
          )}
        </div>

        {/* Image picker bottom sheet */}
        {showImgPicker && (
          <div style={{ position: "fixed", inset: 0, zIndex: 300 }} onClick={() => setShowImgPicker(false)}>
            <div style={{ position: "absolute", inset: 0, background: "rgba(0,0,0,0.4)" }} />
            <div onClick={e => e.stopPropagation()} style={{
              position: "absolute", bottom: 0, left: "50%", transform: "translateX(-50%)",
              width: 375, background: "#fff", borderRadius: "20px 20px 0 0", padding: "20px 20px 48px"
            }}>
              <div style={{ width: 36, height: 4, background: "#e0dbd4", borderRadius: 2, margin: "0 auto 20px" }} />
              <div style={{ fontSize: 16, fontWeight: 700, marginBottom: 16, color: "#1a1714" }}>更换菜品图片</div>
              <label style={{ display: "flex", alignItems: "center", gap: 14, padding: "14px 0", borderBottom: "1px solid #f0ebe3", cursor: "pointer" }}>
                <span style={{ fontSize: 24 }}>📷</span>
                <span style={{ fontSize: 15, color: "#1a1714" }}>拍照</span>
                <input type="file" accept="image/*" capture="environment" style={{ display: "none" }} onChange={handleImgFile} />
              </label>
              <label style={{ display: "flex", alignItems: "center", gap: 14, padding: "14px 0", borderBottom: "1px solid #f0ebe3", cursor: "pointer" }}>
                <span style={{ fontSize: 24 }}>🖼️</span>
                <span style={{ fontSize: 15, color: "#1a1714" }}>从相册选择</span>
                <input type="file" accept="image/*" style={{ display: "none" }} onChange={handleImgFile} />
              </label>
              {dish.imageUrl && (
                <button onClick={() => { onUpdateImage && onUpdateImage(null); setShowImgPicker(false); }} style={{
                  display: "flex", alignItems: "center", gap: 14, padding: "14px 0",
                  background: "none", border: "none", width: "100%", cursor: "pointer"
                }}>
                  <span style={{ fontSize: 24 }}>🗑️</span>
                  <span style={{ fontSize: 15, color: "#e05a3a" }}>删除图片</span>
                </button>
              )}
            </div>
          </div>
        )}

        <button onClick={onBack} style={{
          position: "absolute", top: 52, left: 16,
          background: "rgba(255,255,255,0.9)", border: "none", borderRadius: 12,
          width: 40, height: 40, display: "flex", alignItems: "center", justifyContent: "center",
          fontSize: 18, cursor: "pointer", backdropFilter: "blur(10px)", WebkitTapHighlightColor: "transparent"
        }}>←</button>
        {!chefMode && onToggleFavorite && (
          <button onClick={onToggleFavorite} style={{
            position: "absolute", top: 52, right: 16,
            background: "rgba(255,255,255,0.9)", border: "none", borderRadius: 12,
            width: 40, height: 40, display: "flex", alignItems: "center", justifyContent: "center",
            fontSize: 20, cursor: "pointer", backdropFilter: "blur(10px)", WebkitTapHighlightColor: "transparent"
          }}>
            {dish.is_favorite ? "♥" : "♡"}
          </button>
        )}
      </div>

      {/* Title area */}
      <div style={{ padding: "20px 20px 0" }}>
        <div style={{ display: "flex", alignItems: "flex-start", justifyContent: "space-between" }}>
          <div style={{ flex: 1 }}>
            <div style={{ fontSize: 26, fontWeight: 800, color: "#1a1714", letterSpacing: -0.5 }}>{dish.name}</div>
            <div style={{ display: "flex", gap: 6, flexWrap: "wrap", marginTop: 8 }}>
              <span className="badge badge-category">{dish.category}</span>
              <span className={`badge badge-${dish.difficulty}`}>{dish.difficulty === "easy" ? "简单" : dish.difficulty === "medium" ? "中等" : "较难"}</span>
              <span className="badge" style={{ background: "#f5f0ea", color: "#5a5550" }}>⏱ {dish.estimated_time} 分钟</span>
              <span className="badge" style={{ background: "#f5f0ea", color: "#5a5550" }}>👤 {dish.servings} 人份</span>
            </div>
          </div>
          {!chefMode && onEdit && (
            <button onClick={onEdit} style={{
              background: "#f5f0ea", border: "none", borderRadius: 12,
              padding: "8px 16px", fontSize: 13, fontWeight: 700, color: "#1a1714",
              cursor: "pointer", flexShrink: 0, marginLeft: 12
            }}>编辑</button>
          )}
        </div>

        {/* Metadata */}
        <div style={{ display: "flex", gap: 16, marginTop: 12, paddingTop: 12, borderTop: "1px solid #f5f0ea" }}>
          <div style={{ textAlign: "center" }}>
            <div style={{ fontSize: 18, fontWeight: 700, color: "#c17f3c" }}>{dish.cook_count}</div>
            <div className="caption">已做次数</div>
          </div>
          <div style={{ textAlign: "center" }}>
            <div style={{ fontSize: 18, fontWeight: 700, color: "#c17f3c" }}>{dish.ingredients.length}</div>
            <div className="caption">食材</div>
          </div>
          <div style={{ textAlign: "center" }}>
            <div style={{ fontSize: 18, fontWeight: 700, color: "#c17f3c" }}>{dish.steps.length}</div>
            <div className="caption">步骤</div>
          </div>
          <div style={{ flex: 1, textAlign: "right" }}>
            <div style={{ fontSize: 13, color: "#9a9590" }}>上次烹饪</div>
            <div style={{ fontSize: 13, fontWeight: 600, color: "#1a1714" }}>{dish.last_cooked_date || "—"}</div>
          </div>
        </div>
      </div>

      {/* Section tabs */}
      <div style={{ padding: "16px 20px 0", display: "flex", gap: 0, borderBottom: "1px solid #f0ebe3", overflowX: "auto" }}>
        {[
          { id: "notes", label: "我的备注" },
          { id: "ingredients", label: "食材" },
          { id: "steps", label: "步骤" },
          { id: "sources", label: "参考来源" },
        ].map(tab => (
          <button key={tab.id} onClick={() => setActiveSection(tab.id)} style={{
            background: "none", border: "none", padding: "10px 16px", cursor: "pointer",
            fontSize: 14, fontWeight: 600, color: activeSection === tab.id ? "#c17f3c" : "#9a9590",
            borderBottom: activeSection === tab.id ? "2px solid #c17f3c" : "2px solid transparent",
            whiteSpace: "nowrap", WebkitTapHighlightColor: "transparent"
          }}>{tab.label}</button>
        ))}
      </div>

      {/* Section content */}
      <div style={{ padding: "20px 20px" }}>

        {activeSection === "notes" && (
          <div>
            {dish.custom_notes.length === 0 ? (
              <div className="empty-state" style={{ padding: "40px 0" }}>
                <div className="empty-icon">📝</div>
                <div className="body-text">还没有个人备注。<br />添加你的偏好要求。</div>
              </div>
            ) : (
              <>
                <div style={{ fontSize: 13, color: "#9a9590", marginBottom: 12 }}>这是你对这道菜的个人要求</div>
                {dish.custom_notes.map((note, i) => (
                  <div key={i} className="note-card">
                    <div style={{ fontSize: 15, color: "#3d2200", lineHeight: 1.5 }}>{note}</div>
                  </div>
                ))}
              </>
            )}
          </div>
        )}

        {activeSection === "ingredients" && (
          <div>
            <div style={{ fontSize: 13, color: "#9a9590", marginBottom: 8 }}>{dish.servings} 人份</div>
            {dish.ingredients.map((ing, i) => (
              <div key={i} className="ingredient-row">
                <div style={{ width: 8, height: 8, borderRadius: 4, background: ing.optional ? "#d4cdc5" : "#c17f3c", flexShrink: 0, marginTop: 2 }} />
                <div style={{ flex: 1, fontSize: 15, color: "#1a1714" }}>{ing.name}{ing.note && <span style={{ fontSize: 11, color: "#c17f3c", marginLeft: 4, fontWeight: 500 }}>特殊调料</span>}</div>
                <div style={{ fontSize: 14, fontWeight: 600, color: "#5a5550" }}>{ing.quantity} {ing.unit}</div>
                {ing.optional && <span className="caption" style={{ color: "#b0a89e" }}>可选</span>}
              </div>
            ))}
          </div>
        )}

        {activeSection === "steps" && (
          <div>
            {dish.steps.map((step, i) => (
              <div key={i} style={{ display: "flex", gap: 14, marginBottom: 20 }}>
                <div className="step-number">{step.step_number}</div>
                <div style={{ flex: 1 }}>
                  <div style={{ fontSize: 15, color: "#1a1714", lineHeight: 1.6 }}>{step.instruction}</div>
                  {step.tip && (
                    <div style={{ marginTop: 8, padding: "8px 12px", background: "#fdf3e7", borderRadius: 10, fontSize: 13, color: "#8a6030", lineHeight: 1.4 }}>
                      💡 {step.tip}
                    </div>
                  )}
                </div>
              </div>
            ))}
            <button className="btn-primary" onClick={onCookingMode} style={{ marginTop: 8 }}>
              🍳 开始烹饪模式
            </button>
          </div>
        )}

        {activeSection === "sources" && (
          <div>
            {dish.source_links.length === 0 ? (
              <div className="empty-state" style={{ padding: "40px 0" }}>
                <div className="empty-icon">🔗</div>
