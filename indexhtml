                                      style={{ width: "100%", minHeight: 72, borderRadius: 10, border: "1.5px solid #5a8a5a", padding: "10px 12px", fontSize: 14, fontFamily: "inherit", resize: "none", boxSizing: "border-box", outline: "none" }}
                                      autoFocus
                                    />
                                    <button onClick={() => setEditingChefNote(null)} style={{ marginTop: 6, background: "#5a8a5a", color: "#fff", border: "none", borderRadius: 10, padding: "8px 18px", fontSize: 13, fontWeight: 700, cursor: "pointer" }}>保存</button>
                                  </div>
                                ) : chefNotes[dishId] ? (
                                  <div onClick={() => setEditingChefNote(dishId)} style={{ padding: "10px 12px", background: "#f0f8f0", borderRadius: 10, fontSize: 14, color: "#1a3a1a", lineHeight: 1.5, borderLeft: "3px solid #5a8a5a", cursor: "pointer" }}>
                                    {chefNotes[dishId]}
