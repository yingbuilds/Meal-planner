                    const updatedPlan = { ...mealPlan, days: mealPlan.days.map((day, i) => i === swapModal.dayIndex ? {
                      ...day, meals: { ...day.meals, [swapModal.mealType]: (day.meals[swapModal.mealType] || []).map(id => id === swapModal.dishId ? d.id : id) }
                    } : day) };
                    setMealPlan(updatedPlan);
                    setGroceryList(generateGroceryFromPlan(dishes, updatedPlan));
                    setSwapModal(null); setSwapSearch("");
                    showToast(`✓ 已换成 ${d.name}`);
                  }} style={{ display: "flex", alignItems: "center", gap: 10, padding: "12px 14px", background: "#fff", borderRadius: 14, border: "none", cursor: "pointer", textAlign: "left", WebkitTapHighlightColor: "transparent" }}>
