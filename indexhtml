                              <div style={{ marginTop: 14, borderTop: "1px solid #f5f0ea", paddingTop: 14 }}>
                                <div style={{ fontSize: 11, fontWeight: 700, color: "#5a8a5a", letterSpacing: 0.5, marginBottom: 6 }}>📝 厨师备注（仅自己可见）</div>
                                {editingChefNote === dishId ? (
