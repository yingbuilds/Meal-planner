  "水","热水","冷水","高汤",
  "小苏打","泡打粉","酵母",
]);

function isPantryStaple(name) {
  const n = name.trim();
  if (PANTRY_STAPLES.has(n)) return true;
  // strip parenthetical notes like "生抽（腌肉）"
  const base = n.replace(/[（(][^）)]*[）)]/g, "").trim();
  return PANTRY_STAPLES.has(base);
}

