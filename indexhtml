  const [showImagePicker, setShowImagePicker] = useState(false);
  const [stepsMode, setStepsMode] = useState("structured");
  const [pasteText, setPasteText] = useState("");
  const [aiPrompt, setAiPrompt] = useState("");
  const [aiLoading, setAiLoading] = useState(false);
  const [showAiPrompt, setShowAiPrompt] = useState(false);

  const update = (key, val) => setForm(f => ({ ...f, [key]: val }));

  const handleImageFile = (e) => {
    const file = e.target.files && e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = ev => { setImageUrl(ev.target.result); setShowImagePicker(false); };
    reader.readAsDataURL(file);
  };

  const GEMINI_KEY = "AIzaSyC1fThUx6x_BBDsuDvY2YscOixmbC20tz0";
  const callGemini = async (prompt) => {
    const res = await fetch(
      `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=${GEMINI_KEY}`,
      { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ contents: [{ parts: [{ text: prompt }] }] }) }
    );
    if (!res.ok) throw new Error(`Gemini error ${res.status}`);
    const data = await res.json();
    return data.candidates?.[0]?.content?.parts?.[0]?.text || "";
  };

  const handleAiGenerate = async (promptOverride) => {
    const name = promptOverride || form.name || "家常菜";
    setAiLoading(true);
    try {
      const raw = await callGemini(
        `你是一个中餐烹饪助手。请根据菜名"${name}"生成一份家庭烹饪食谱。
返回严格的JSON格式，不要加任何解释或markdown代码块：
{"category":"必须是以下之一：猪肉/牛肉/羊肉/鸡肉/鸭肉/海鲜/蔬菜/豆腐/主食/汤品","ingredients":[{"name":"食材名","quantity":"用量","unit":"单位","unusual":false}],"steps":[{"step_number":1,"instruction":"步骤说明","tip":"小技巧或空字符串"}]}
食材只列需要购买的原材料，每个是单独一个词（不是短语）。不要包含盐糖油酱油生抽老抽料酒味精鸡精淀粉香油等家庭常备调料。鱼露豆豉豆瓣酱椰浆咖喱等特殊调料需包含并unusual设为true。步骤3-6个，每步不超过60字。`
      );
      const _s1=raw.indexOf("{"),_e1=raw.lastIndexOf("}");
      const json = JSON.parse(_s1>-1&&_e1>-1 ? raw.slice(_s1,_e1+1) : "{}");
      if (json.steps) update("steps", json.steps.map((s, i) => ({ step_number: i + 1, instruction: s.instruction || "", tip: s.tip || "" })));
      if (json.ingredients) update("ingredients", json.ingredients.map(ing => ({ name: ing.name, quantity: ing.quantity || "", unit: ing.unit || "", optional: false, ...(ing.unusual ? { note: "特殊调料" } : {}) })));
      if (json.category) { const cat = normalizeCategory(json.category); update("category", cat); update("image", CATEGORY_EMOJI[cat] || "🍳"); }
      setStepsMode("structured");
      showToast("✨ AI 已填写步骤、食材、分类");
    } catch (e) {
      console.error("AI generate error, falling back:", e);
      const result = generateRecipeFromName(name);
      update("steps", result.steps);
      update("ingredients", result.ingredients);
      if (result.category) { update("category", result.category); if (CATEGORY_EMOJI[result.category]) update("image", CATEGORY_EMOJI[result.category]); }
