function App() {
  const [activeTab, setActiveTab] = useState("home");
  const [dishes, setDishes] = useState(SEED_DISHES);
  const [mealPlan, setMealPlan] = useState(SEED_MEAL_PLAN);
  const [groceryList, setGroceryList] = useState(SEED_GROCERY);
  const [navStack, setNavStack] = useState([{ screen: "home" }]);
  const [cookingDish, setCookingDish] = useState(null);
  const [toast, setToast] = useState(null);
  const [toastTimeout, setToastTimeout] = useState(null);
  const [planSettings, setPlanSettings] = useState({
    days: 5,
    meals: { breakfast: false, lunch: true, dinner: false },
    mealComposition: {
      breakfast: { meat: 0, veg: 0 },
      lunch: { meat: 2, veg: 1 },
      dinner: { meat: 1, veg: 1 }
    }
  });

  const current = navStack[navStack.length - 1];

  const showToast = (msg) => {
    if (toastTimeout) clearTimeout(toastTimeout);
    setToast(msg);
    const t = setTimeout(() => setToast(null), 2000);
    setToastTimeout(t);
  };

  const navigate = (screen, param) => {
    if (["home", "dishes", "plan", "grocery", "share"].includes(screen)) {
      setActiveTab(screen);
      setNavStack([{ screen }]);
    } else {
      setNavStack(prev => [...prev, { screen, param }]);
    }
  };

  const goBack = () => {
    if (navStack.length > 1) {
      setNavStack(prev => prev.slice(0, -1));
    }
  };

  const renderScreen = () => {
    const { screen, param } = current;

    if (cookingDish) {
      return <CookingModeScreen dish={cookingDish} onClose={() => setCookingDish(null)} />;
    }

    if (screen === "home") return (
      <HomeScreen dishes={dishes} mealPlan={mealPlan} groceryList={groceryList} onNavigate={navigate} showToast={showToast} />
    );

    if (screen === "dishes") return (
      <DishLibraryScreen dishes={dishes} setDishes={setDishes} onNavigate={navigate} />
    );

    if (screen === "dish-detail") {
      const dish = getDishById(dishes, param);
      return (
        <DishDetailScreen
          dish={dish}
          onBack={goBack}
          onCookingMode={() => setCookingDish(dish)}
          onEdit={() => navigate("edit-dish", param)}
          onToggleFavorite={() => setDishes(prev => prev.map(d => d.id === param ? { ...d, is_favorite: !d.is_favorite } : d))}
          onUpdateImage={(url) => setDishes(prev => prev.map(d => d.id === param ? { ...d, imageUrl: url } : d))}
        />
      );
    }

    if (screen === "edit-dish") {
      const dish = getDishById(dishes, param);
      return (
        <EditDishScreen
          dish={dish}
          onBack={goBack}
          showToast={showToast}
          onSave={(updated) => {
            setDishes(prev => prev.map(d => d.id === param ? updated : d));
            goBack();
          }}
        />
      );
    }

    if (screen === "add-dish") return (
      <AddDishScreen onBack={goBack} showToast={showToast} onSave={(newDish) => {
        setDishes(prev => [...prev, newDish]);
        goBack();
        showToast("✓ 菜品已保存！");
      }} />
    );

    if (screen === "plan") return (
      <PlanScreen dishes={dishes} mealPlan={mealPlan} setMealPlan={setMealPlan} setGroceryList={setGroceryList} planSettings={planSettings} setPlanSettings={setPlanSettings} onNavigate={navigate} showToast={showToast} />
    );

    if (screen === "grocery") return (
      <GroceryScreen groceryList={groceryList} setGroceryList={setGroceryList} showToast={showToast} />
    );

    if (screen === "share") return (
      <ShareScreen dishes={dishes} mealPlan={mealPlan} groceryList={groceryList} planSettings={planSettings} showToast={showToast}
        onViewDishLibrary={() => navigate("chef-dish-library")} />
    );

    if (screen === "chef-dish-library") return (
      <ChefDishLibraryScreen dishes={dishes} onBack={goBack} onDishDetail={(id) => navigate("chef-dish-detail", id)} />
    );

    if (screen === "chef-dish-detail") {
      const dish = getDishById(dishes, param);
      return <DishDetailScreen dish={dish} onBack={goBack} onCookingMode={() => setCookingDish(dish)} chefMode={true} />;
    }

    return <HomeScreen dishes={dishes} mealPlan={mealPlan} groceryList={groceryList} onNavigate={navigate} showToast={showToast} />;
  };

  const showNav = !cookingDish;
  const showTabs = ["home", "dishes", "plan", "grocery", "share"].includes(current.screen) && navStack.length === 1;

  return (
    <div className="app-shell">
      {renderScreen()}
      {showNav && showTabs && <BottomNav active={activeTab} onNavigate={navigate} />}
      {toast && <Toast msg={toast} />}
    </div>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App />);
</script>
</body>
</html>
