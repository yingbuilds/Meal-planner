            <div style={{ fontSize: 16, fontWeight: 700, marginBottom: 16, color: "#1a1714" }}>选择图片来源</div>
            <label style={{ display: "flex", alignItems: "center", gap: 14, padding: "14px 0", borderBottom: "1px solid #f0ebe3", cursor: "pointer" }}>
              <span style={{ fontSize: 24 }}>📷</span><span style={{ fontSize: 15, color: "#1a1714" }}>拍照</span>
              <input type="file" accept="image/*" capture="environment" style={{ display: "none" }} onChange={handleImageFile} />
