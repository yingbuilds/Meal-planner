    },
  };

  // category inference from name keywords (runs even without template match)
  function inferCategory(n) {
    if (/猪|排骨|五花|猪肉|猪蹄|肘子|猪手|回锅|腊肉|咸肉|猪杂/.test(n)) return "猪肉";
    if (/牛|牛肉|牛腩|牛排|牛杂|牛筋/.test(n)) return "牛肉";
    if (/鸡|鸭|鹅|乌鸡|童子鸡/.test(n)) return "鸡肉";
    if (/鱼|虾|蟹|蚝|蛤|海鲜|龙虾|扇贝|螺|贝|鱿|墨鱼|章鱼|鲍|海参|生蚝|田螺|花甲|蛏|蛤蜊|皮皮虾|濑尿虾|蒸蟹|鲫鱼|鲈鱼|带鱼|鳕鱼|三文鱼/.test(n)) return "海鲜";
    if (/豆腐|豆干|腐竹|豆皮|千张|老豆腐|嫩豆腐/.test(n)) return "豆腐";
    if (/汤|羹|炖盅|煲/.test(n)) return "汤品";
    if (/饭|面|饺|包|饼|粥|馄饨|粉|米|炒饭|拌面|烩饭|炒面/.test(n)) return "主食";
