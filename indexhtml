        {/* Selected day */}
        {(() => {
          const day = mealPlan.days[expandedDay];
          return (
            <div>
              <div style={{ fontSize: 16, fontWeight: 700, color: "#1a1714", marginBottom: 4 }}>{day.date}</div>
              {day.notes && (
                <div style={{ padding: "10px 14px", background: "#fff8ed", borderRadius: 12, fontSize: 13, color: "#8a6030", marginBottom: 12, borderLeft: "3px solid #c17f3c" }}>
                  📌 {day.notes}
                </div>
              )}

              {activeMealSlots.map(mealType => (
                <div key={mealType} style={{ marginBottom: 14 }}>
                  <div style={{ fontSize: 11, fontWeight: 700, color: "#9a9590", letterSpacing: 1, textTransform: "uppercase", marginBottom: 8 }}>{MEAL_LABELS[mealType]}</div>
