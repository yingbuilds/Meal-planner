        </div>
      )}

      <style>{`@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }`}</style>
    </div>
  );
}


// ─── WEEKLY PLAN SCREEN ───────────────────────────────────────────
const MEAL_LABELS = { breakfast: "早餐", lunch: "午餐", dinner: "晚餐" };
const WEEKDAYS = ["周一","周二","周三","周四","周五","周六","周日"];

function buildDateLabel(dayIndex) {
  const base = new Date(2026, 4, 11); // May 11 = Monday baseline
  base.setDate(base.getDate() + dayIndex);
  const m = base.getMonth() + 1, d = base.getDate();
  return { date: `${WEEKDAYS[dayIndex % 7]} ${m}月${d}日`, short: WEEKDAYS[dayIndex % 7] };
}

const VEG_CATEGORIES = new Set(["蔬菜", "豆腐"]);
function isVegDish(d) { return VEG_CATEGORIES.has(d.category); }

function generatePlan(dishes, planSettings) {
  const activeMealSlots = Object.entries(planSettings.meals).filter(([, v]) => v).map(([k]) => k);
  if (activeMealSlots.length === 0 || dishes.length === 0) return null;
  const shuffle = arr => { const a = [...arr]; for (let i = a.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); [a[i], a[j]] = [a[j], a[i]]; } return a; };
  const meatPool = shuffle(dishes.filter(d => !isVegDish(d)));
  const vegPool = shuffle(dishes.filter(d => isVegDish(d)));
  let meatPtr = 0, vegPtr = 0;
  const nextMeat = () => { if (meatPool.length === 0) return null; const d = meatPool[meatPtr % meatPool.length]; meatPtr++; return d.id; };
  const nextVeg = () => { if (vegPool.length === 0) return null; const d = vegPool[vegPtr % vegPool.length]; vegPtr++; return d.id; };
  const today = new Date();
  const base = new Date(today); base.setDate(today.getDate() - today.getDay() + 1);
  const days = Array.from({ length: planSettings.days }, (_, i) => {
    const dt = new Date(base); dt.setDate(base.getDate() + i);
    const m = dt.getMonth() + 1, d = dt.getDate();
    const meals = {};
    activeMealSlots.forEach(slot => {
      const comp = planSettings.mealComposition?.[slot] || { meat: 1, veg: 0 };
      const ids = [];
      for (let n = 0; n < comp.meat; n++) { const id = nextMeat(); if (id) ids.push(id); }
      for (let n = 0; n < comp.veg; n++) { const id = nextVeg(); if (id) ids.push(id); }
      meals[slot] = ids;
    });
    ["breakfast","lunch","dinner"].forEach(s => { if (!meals[s]) meals[s] = []; });
    return { date: `${WEEKDAYS[i % 7]} ${m}月${d}日`, short: WEEKDAYS[i % 7], meals, notes: "", status: "pending" };
  });
  const startDay = days[0]?.date.split(" ")[1] || "";
  const endDay = days[days.length - 1]?.date.split(" ")[1] || "";
  return { id: `mp${Date.now()}`, week_range: `${startDay}–${endDay}`, days };
}

const GROCERY_CATEGORY = {
  "猪肉": "肉类", "牛肉": "肉类", "羊肉": "肉类", "鸡肉": "肉类", "鸭肉": "肉类",
  "海鲜": "海鲜", "蔬菜": "蔬菜", "豆腐": "豆制品", "主食": "主食", "汤品": "肉类",
};

function generateGroceryFromPlan(dishes, mealPlan) {
  const dishIds = new Set();
  (mealPlan?.days || []).forEach(day => {
    Object.values(day.meals || {}).forEach(slot => (slot || []).forEach(id => dishIds.add(id)));
  });
  const ingredientMap = {};
  dishIds.forEach(id => {
    const dish = dishes.find(d => d.id === id);
    if (!dish) return;
    (dish.ingredients || []).forEach(ing => {
      if (isPantryStaple(ing.name)) return;
      const key = ing.name;
      const dishCat = GROCERY_CATEGORY[dish.category] || "其他";
      if (!ingredientMap[key]) {
        ingredientMap[key] = {
          id: `gi_${key}`, name: key,
          total_quantity: ing.quantity || 1, unit: ing.unit || "",
          category: dishCat, checked: false
        };
      } else {
        ingredientMap[key].total_quantity += (ing.quantity || 1);
      }
    });
  });
  return { id: `g${Date.now()}`, linked_meal_plan_id: mealPlan?.id, items: Object.values(ingredientMap) };
}

function PlanScreen({ dishes, mealPlan, setMealPlan, setGroceryList, planSettings, setPlanSettings, onNavigate, showToast }) {
  const [swapModal, setSwapModal] = useState(null);
  const [swapSearch, setSwapSearch] = useState("");
  const [showSettings, setShowSettings] = useState(false);
  const [settingsSnapshot, setSettingsSnapshot] = useState(null);
  const [addDishModal, setAddDishModal] = useState(null); // { dayIndex, mealType }
  const [addDishSearch, setAddDishSearch] = useState("");

  const activeMealSlots = Object.entries(planSettings.meals).filter(([, v]) => v).map(([k]) => k);
  const mealOrder = ["breakfast", "lunch", "dinner"];
  const orderedActiveSlots = mealOrder.filter(s => planSettings.meals[s]);

  const handleGenerate = () => {
    if (dishes.length === 0) { showToast("先添加一些菜品吧！"); return; }
    const plan = generatePlan(dishes, planSettings);
    if (!plan) { showToast("请先在设置中开启至少一个餐次"); return; }
    setMealPlan(plan);
    const grocery = generateGroceryFromPlan(dishes, plan);
    setGroceryList(grocery);
    showToast("✨ 菜单已生成！");
  };

  const regenerateDay = (dayIndex) => {
    const usedIds = new Set();
    mealPlan.days.forEach((d, i) => {
      if (i !== dayIndex) Object.values(d.meals || {}).forEach(slot => slot.forEach(id => usedIds.add(id)));
    });
    const shuffle = arr => { const a = [...arr]; for (let i = a.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); [a[i], a[j]] = [a[j], a[i]]; } return a; };
    const meatSrc = dishes.filter(d => !isVegDish(d) && !usedIds.has(d.id));
    const vegSrc = dishes.filter(d => isVegDish(d) && !usedIds.has(d.id));
    const meatPool = shuffle(meatSrc.length > 0 ? meatSrc : dishes.filter(d => !isVegDish(d)));
    const vegPool = shuffle(vegSrc.length > 0 ? vegSrc : dishes.filter(d => isVegDish(d)));
    let meatPtr = 0, vegPtr = 0;
    const nextMeat = () => { if (meatPool.length === 0) return null; const d = meatPool[meatPtr % meatPool.length]; meatPtr++; return d.id; };
    const nextVeg = () => { if (vegPool.length === 0) return null; const d = vegPool[vegPtr % vegPool.length]; vegPtr++; return d.id; };
    const newMeals = {};
    orderedActiveSlots.forEach(slot => {
      const comp = planSettings.mealComposition?.[slot] || { meat: 1, veg: 0 };
      const ids = [];
      for (let n = 0; n < comp.meat; n++) { const id = nextMeat(); if (id) ids.push(id); }
      for (let n = 0; n < comp.veg; n++) { const id = nextVeg(); if (id) ids.push(id); }
      newMeals[slot] = ids;
    });
    ["breakfast","lunch","dinner"].forEach(s => { if (!newMeals[s]) newMeals[s] = []; });
    const updatedPlan = { ...mealPlan, days: mealPlan.days.map((d, i) => i === dayIndex ? { ...d, meals: newMeals } : d) };
    setMealPlan(updatedPlan);
    setGroceryList(generateGroceryFromPlan(dishes, updatedPlan));
    showToast("🔄 当日菜单已重新生成！");
  };

  const addDishToSlot = (dishId, dayIndex, mealType) => {
    const updatedPlan = { ...mealPlan, days: mealPlan.days.map((d, i) => i === dayIndex ? {
      ...d, meals: { ...d.meals, [mealType]: [...(d.meals[mealType] || []), dishId] }
    } : d) };
    setMealPlan(updatedPlan);
    setGroceryList(generateGroceryFromPlan(dishes, updatedPlan));
    setAddDishModal(null);
    showToast("✓ 已添加");
  };

  const removeDishFromSlot = (dishId, dayIndex, mealType) => {
    const updatedPlan = { ...mealPlan, days: mealPlan.days.map((d, i) => i === dayIndex ? {
      ...d, meals: { ...d.meals, [mealType]: (d.meals[mealType] || []).filter(id => id !== dishId) }
    } : d) };
    setMealPlan(updatedPlan);
    setGroceryList(generateGroceryFromPlan(dishes, updatedPlan));
    showToast("✓ 已移除");
  };

  return (
    <div className="screen">
      {/* Header */}
      <div style={{ padding: "52px 20px 0", display: "flex", justifyContent: "space-between", alignItems: "flex-start" }}>
        <div>
          <div className="screen-title">每周菜单</div>
          {mealPlan && <div className="body-text" style={{ marginTop: 3 }}>{mealPlan.week_range}</div>}
        </div>
        <button onClick={() => { setSettingsSnapshot(JSON.stringify(planSettings)); setShowSettings(true); }} style={{
          width: 40, height: 40, borderRadius: 12, background: "#f5f0ea", border: "none",
          fontSize: 18, cursor: "pointer", display: "flex", alignItems: "center", justifyContent: "center",
          WebkitTapHighlightColor: "transparent", marginTop: 4
        }}>⚙️</button>
      </div>

      {!mealPlan ? (
        <div className="empty-state" style={{ marginTop: 40 }}>
          <div className="empty-icon">📅</div>
          <div className="section-title">还没有生成菜单</div>
          <div className="body-text" style={{ maxWidth: 240 }}>根据你的菜品库自动排菜</div>
          <button className="btn-primary" style={{ marginTop: 16, maxWidth: 200 }} onClick={handleGenerate}>✨ 生成菜单</button>
        </div>
      ) : (
        <div style={{ padding: "16px 20px", display: "flex", flexDirection: "column", gap: 12 }}>

          {mealPlan.days.map((day, dayIndex) => (
            <div key={dayIndex} className="day-card">
              <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 12 }}>
                <div style={{ fontSize: 16, fontWeight: 700, color: "#1a1714" }}>{day.date}</div>
                <button onClick={() => regenerateDay(dayIndex)} style={{
                  background: "#f5f0ea", border: "none", borderRadius: 10, padding: "6px 10px",
                  fontSize: 12, fontWeight: 600, color: "#5a5550", cursor: "pointer", WebkitTapHighlightColor: "transparent"
                }}>🔄 重排</button>
              </div>

              {orderedActiveSlots.map((mealType, slotIdx) => {
                const slotDishes = (day.meals || {})[mealType] || [];
                return (
                  <div key={mealType} style={{ marginBottom: slotIdx < orderedActiveSlots.length - 1 ? 10 : 0 }}>
                    <div style={{ fontSize: 11, fontWeight: 700, color: "#9a9590", letterSpacing: 0.5, marginBottom: 6 }}>{MEAL_LABELS[mealType]}</div>
                    <div style={{ display: "flex", flexDirection: "column", gap: 6 }}>
                      {slotDishes.length === 0 && (
                        <div style={{ fontSize: 13, color: "#b0a89e", padding: "6px 0" }}>暂无菜品</div>
                      )}
                      {slotDishes.map(dishId => {
                        const d = getDishById(dishes, dishId);
                        if (!d) return null;
                        return (
                          <div key={dishId} style={{ display: "flex", alignItems: "center", gap: 6 }}>
                            <button onClick={() => onNavigate("dish-detail", dishId)} style={{
                              flex: 1, display: "flex", alignItems: "center", gap: 8, background: "#fff", borderRadius: 10,
                              padding: "8px 10px", border: "none", cursor: "pointer", textAlign: "left", WebkitTapHighlightColor: "transparent"
                            }}>
                              <span style={{ fontSize: 20 }}>{d.image}</span>
