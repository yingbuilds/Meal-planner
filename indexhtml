                                    + 添加我的备注
                                  </button>
                                )}
                              </div>
                            </div>
                          )}
                        </div>
                      );
                    })}
                  </div>
                </div>
              ))}
            </div>
          );
        })()}

        {/* Grocery section */}
        <button onClick={() => setShowGrocery(!showGrocery)} style={{
          background: "#f5f0ea", border: "none", borderRadius: 14, padding: "14px 16px",
          display: "flex", alignItems: "center", justifyContent: "space-between",
          cursor: "pointer", WebkitTapHighlightColor: "transparent"
        }}>
          <div style={{ display: "flex", alignItems: "center", gap: 10 }}>
            <span style={{ fontSize: 22 }}>🛒</span>
            <div style={{ textAlign: "left" }}>
              <div style={{ fontSize: 15, fontWeight: 700, color: "#1a1714" }}>采购清单</div>
              <div className="caption">共 {groceryList?.items?.length} 项</div>
            </div>
          </div>
          <span style={{ color: "#9a9590" }}>{showGrocery ? "▲" : "▼"}</span>
        </button>

        {showGrocery && groceryList && (
          <div className="card" style={{ padding: "8px 16px" }}>
            {groceryList.items.slice(0, 12).map(item => (
              <div key={item.id} className="checkbox-row" onClick={() => toggleCheck(item.id)}>
                <div className={`checkbox ${checkedItems[item.id] ? "checked" : ""}`}>
                  {checkedItems[item.id] && <span style={{ color: "#fff", fontSize: 12, fontWeight: 700 }}>✓</span>}
                </div>
                <div style={{ flex: 1, fontSize: 14, color: checkedItems[item.id] ? "#b0a89e" : "#1a1714", textDecoration: checkedItems[item.id] ? "line-through" : "none" }}>
                  {item.name}
                </div>
                <div style={{ fontSize: 13, color: "#5a5550" }}>{item.quantity} {item.unit}</div>
              </div>
            ))}
            {groceryList.items.length > 12 && (
              <div className="caption" style={{ padding: "8px 0", textAlign: "center" }}>还有 {groceryList.items.length - 12} 项...</div>
            )}
          </div>
        )}
      </div>
    </div>
  );
}

