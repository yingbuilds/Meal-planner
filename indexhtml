    { id: "home", icon: "🏠", label: "首页" },
    { id: "dishes", icon: "🍽️", label: "菜品库" },
    { id: "plan", icon: "📅", label: "菜单" },
    { id: "grocery", icon: "🛒", label: "采购" },
    { id: "share", icon: "👨‍🍳", label: "厨师" },
  ];
  return (
    <div className="bottom-nav">
      {tabs.map(tab => (
        <button
          key={tab.id}
          className={`nav-item ${active === tab.id ? "active" : "inactive"}`}
          onClick={() => onNavigate(tab.id)}
        >
          <span className="nav-icon">{tab.icon}</span>
          <span className="nav-label">{tab.label}</span>
          {active === tab.id && <div className="nav-dot" />}
        </button>
      ))}
    </div>
  );
}

function Toast({ msg }) {
  if (!msg) return null;
  return <div className="toast">{msg}</div>;
}

