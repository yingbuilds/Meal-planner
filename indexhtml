function normalizeCategory(raw) {
  if (!raw) return "猪肉";
  if (VALID_CATEGORIES.includes(raw)) return raw;
  if (/鱼|虾|蟹|贝|螺|蚌|蛤|蚝|海鲜|海产|水产/.test(raw)) return "海鲜";
  if (/鸭/.test(raw)) return "鸭肉";
  if (/鸡/.test(raw)) return "鸡肉";
  if (/羊/.test(raw)) return "羊肉";
  if (/牛/.test(raw)) return "牛肉";
  if (/猪|排骨|五花|肉类/.test(raw)) return "猪肉";
  if (/汤/.test(raw)) return "汤品";
  if (/豆腐/.test(raw)) return "豆腐";
  if (/蔬菜|素/.test(raw)) return "蔬菜";
  if (/饭|面|粉|主食|粥/.test(raw)) return "主食";
  return "猪肉";
}

